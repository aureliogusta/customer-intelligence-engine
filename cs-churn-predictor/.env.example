# CS Churn Predictor — variáveis de ambiente
# Copie para .env e ajuste os valores

# ── PostgreSQL + pgvector (memória semântica) ─────────────────────────────────
# Deixe em branco para desabilitar (sistema funciona sem pgvector)
PGVECTOR_DSN=postgresql://postgres:postgres@localhost:5432/churn_db

# ── Embedding ─────────────────────────────────────────────────────────────────
# "hash"   → offline, determinístico, zero dependências (padrão)
# "openai" → semântica real, requer OPENAI_API_KEY
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSIONS=384
# OPENAI_API_KEY=sk-...
# OPENAI_EMBED_MODEL=text-embedding-3-small

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_TIMEOUT=120

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001

# ── Paths (opcionais — padrão: subpastas do projeto) ──────────────────────────
# MODELS_DIR=ml/models
# DATA_DIR=data
# LOGS_DIR=logs

# ── ML ────────────────────────────────────────────────────────────────────────
HIGH_RISK_THRESHOLD=0.70
MEDIUM_RISK_THRESHOLD=0.40
RETRAIN_ON_DRIFT=false

# ── Monitoramento ─────────────────────────────────────────────────────────────
MRR_ALERT_THRESHOLD=50000
